<Page
    x:Class="UTPCalendar.View.Pages.HelpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <StackPanel Spacing="24" MaxWidth="700" HorizontalAlignment="Left">

            <TextBlock Text="Ayuda y Soporte" Style="{ThemeResource TitleTextBlockStyle}"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Text="¿Cómo utilizar la aplicación?" FontWeight="SemiBold" FontSize="18"/>
                    <TextBlock Text="1. Ve a la pestaña 'Usuarios' y registra tu código y contraseña de la UTP." TextWrapping="Wrap"/>
                    <TextBlock Text="2. Marca a tu usuario como 'Predeterminado' tocando el icono de la estrella." TextWrapping="Wrap"/>
                    <TextBlock Text="3. Haz clic en 'Generar .ics' o ve a la pestaña de Calendario para extraer y visualizar tus clases." TextWrapping="Wrap"/>
                    <TextBlock Text="4. Configura Nextcloud si deseas que el horario se sincronice directamente a tu teléfono móvil." TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Page>