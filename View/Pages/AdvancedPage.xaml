<Page
    x:Class="UTPCalendar.View.Pages.AdvancedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="50"/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <ScrollViewer>
            <StackPanel Spacing="16" MaxWidth="1000" HorizontalAlignment="Left">

                <TextBlock Text="Ajustes Avanzados" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="Rango de Búsqueda" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="4,8,0,4"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">

                        <StackPanel>
                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Meses de consulta" FontWeight="Medium"/>
                                    <TextBlock Text="Define cuántos meses extraer (máximo 3)." 
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <ComboBox Grid.Column="1" MinWidth="150" VerticalAlignment="Center"
                                          ItemsSource="{x:Bind ViewModel.AvailableMonths, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SearchRangeMonths, Mode=TwoWay}"
                                          IsEnabled="{x:Bind ViewModel.IsMonthsModeEnabled, Mode=OneWay}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Búsqueda Personalizada" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="4,8,0,4"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="16">
                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Usar fechas exactas" FontWeight="Medium"/>
                                    <TextBlock Text="Ignora el rango por meses y usa los calendarios." 
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.UseCustomDateRange, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,-8,0"/>
                            </Grid>

                            <StackPanel>
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CalendarDatePicker x:Name="StartDatePicker" Header="Fecha Inicio" Width="180"
                                                        Date="{x:Bind ViewModel.CustomStartDate, Mode=TwoWay}"
                                                        IsEnabled="{x:Bind ViewModel.UseCustomDateRange, Mode=OneWay}"/>

                                    <CalendarDatePicker x:Name="EndDatePicker" Grid.Column="1" Header="Fecha Fin" Width="180"
                                                        Date="{x:Bind ViewModel.CustomEndDate, Mode=TwoWay}"
                                                        IsEnabled="{x:Bind ViewModel.UseCustomDateRange, Mode=OneWay}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Sistema" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="4,8,0,4"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Caché de Feriados" FontWeight="Medium"/>
                                <TextBlock Text="{x:Bind ViewModel.HolidaysStatus, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Actualizar" Click="RefreshHolidays_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Inicio Automático" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="4,8,0,4"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="16">

                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Usuario predeterminado" FontWeight="Medium"/>
                                    <TextBlock Text="Perfil activo en segundo plano (cámbialo en la pestaña Usuarios)." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <Grid Width="32" Height="32" CornerRadius="16" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Visibility="{x:Bind ViewModel.NoProfilePicture, Mode=OneWay}">
                                        <FontIcon Glyph="&#xE77B;" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>
                                    <PersonPicture ProfilePicture="{x:Bind ViewModel.DefaultUserProfilePicture, Mode=OneWay}" Width="32" Height="32" Visibility="{x:Bind ViewModel.HasProfilePicture, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind ViewModel.ShortDisplayName, Mode=OneWay}" 
           VerticalAlignment="Center" 
           FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>

                            <MenuFlyoutSeparator Margin="-16,0,-16,0"/>

                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Ejecutar al encender la PC" FontWeight="Medium"/>
                                    <TextBlock Text="{x:Bind ViewModel.RepairStatusText, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <Button Grid.Column="1" Content="Reparar Servicio" Click="RepairAutostart_Click" IsEnabled="{x:Bind ViewModel.AutostartEnabled, Mode=OneWay}" VerticalAlignment="Center"/>
                                <ToggleSwitch Grid.Column="2" IsOn="{x:Bind ViewModel.AutostartEnabled, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,-8,0"/>
                            </Grid>

                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>