<Page
    x:Class="UTPCalendar.View.Pages.CalendarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UTPCalendar.View.Pages"
    xmlns:models="using:UTPCalendar.Models">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Calendario" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,24"/>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="16" Width="350">

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Horario de:" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <ComboBox ItemsSource="{x:Bind ViewModel.Users, Mode=OneWay}" 
                                  SelectedItem="{x:Bind ViewModel.SelectedUser, Mode=TwoWay}"
                                  DisplayMemberPath="Username" 
                                  HorizontalAlignment="Stretch"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <PersonPicture Grid.Column="0" ProfilePicture="{x:Bind ViewModel.SelectedUser.ProfileImageSource, Mode=OneWay}"
                                           DisplayName="{x:Bind ViewModel.SelectedUser.FullName, Mode=OneWay}"
                                           Height="48" Width="48" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedUserShortName, Mode=OneWay}" 
                                       VerticalAlignment="Center" FontWeight="Bold" FontSize="16" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <CalendarView x:Name="MainCalendar" Language="es-PE" FirstDayOfWeek="Monday" SelectionMode="Single"
                                  SelectedDatesChanged="MainCalendar_SelectedDatesChanged" CalendarViewDayItemChanging="MainCalendar_CalendarViewDayItemChanging"
                                  Height="380" HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0" />
                </Border>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
            Content="Ir a Hoy" 
            Click="GoToToday_Click" 
            HorizontalAlignment="Stretch" 
            Margin="0,0,4,0"/>

                    <Grid Grid.Column="1" Margin="4,0,0,0">
                        <Button Content="Actualizar" 
                Click="Refresh_Click" 
                Style="{ThemeResource AccentButtonStyle}" 
                HorizontalAlignment="Stretch"/>
                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                      Width="20" Height="20" 
                      HorizontalAlignment="Right" 
                      Margin="0,0,12,0"
                      Foreground="White"/>
                    </Grid>
                </Grid>
            </StackPanel>

            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{x:Bind ViewModel.SelectedDateText, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,16"/>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.FilteredEvents, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:CalendarEvent">
                                <Grid Padding="12" Margin="0,4" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind StartTime}" FontWeight="SemiBold" FontSize="14.5"/>
                                        <TextBlock Text="{x:Bind EndTime}" FontWeight="SemiBold" FontSize="14.5"/>
                                    </StackPanel>

                                    <Border Grid.Column="1" Background="{ThemeResource SystemAccentColor}" Margin="0,4" Width="2" HorizontalAlignment="Center"/>

                                    <StackPanel Grid.Column="2" Margin="16,0" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind CourseName}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap"/>
                                        <TextBlock Text="{x:Bind ReminderText}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <Border Grid.Column="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Location}" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" FontWeight="SemiBold" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.Header>
                            <TextBlock Text="Día libre. No hay clases programadas." Visibility="{x:Bind ViewModel.IsEmptyDay, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontStyle="Italic" Margin="12,20,0,0"/>
                        </ListView.Header>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>