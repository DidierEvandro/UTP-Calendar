<Page
    x:Class="UTPCalendar.View.Pages.NextcloudPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <ScrollViewer>
            <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">

                <StackPanel Spacing="4">
                    <TextBlock Text="Nextcloud" Style="{ThemeResource TitleTextBlockStyle}"/>
                    <TextBlock Text="Sincroniza tus horarios automáticamente con tu nube personal." 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Integración" FontWeight="SemiBold" FontSize="16" Margin="4,0,0,4"/>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" HorizontalAlignment="Stretch">
                        <Grid Padding="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock Text="Subir a la nube automáticamente" FontWeight="Medium"/>
                                <TextBlock Text="Al terminar la extracción, se enviará el archivo .ics a tu servidor WebDAV." 
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.IsEnabled, Mode=TwoWay}" MinWidth="0" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Servidor y credenciales" FontWeight="SemiBold" FontSize="16" Margin="4,0,0,4"/>

                    <ContentControl IsEnabled="{x:Bind ViewModel.IsEnabled, Mode=OneWay}" HorizontalContentAlignment="Stretch">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" HorizontalAlignment="Stretch">
                            <StackPanel>

                                <Grid Padding="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock Text="URL del servidor" FontWeight="Medium"/>
                                        <TextBlock Text="Ej: https://nube.tu-servidor.com/remote.php/webdav/" 
                                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay}" 
                                             Width="350" VerticalAlignment="Center" PlaceholderText="Enlace del servidor"/>
                                </Grid>

                                <MenuFlyoutSeparator Margin="0"/>

                                <Grid Padding="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock Text="Token de aplicación" FontWeight="Medium"/>
                                        <TextBlock Text="Se recomienda crear una contraseña de aplicación específica." 
                                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <PasswordBox Grid.Column="1" Password="{x:Bind ViewModel.Token, Mode=TwoWay}" 
                                                 Width="350" VerticalAlignment="Center"/>
                                </Grid>

                                <MenuFlyoutSeparator Margin="0"/>

                                <Grid Padding="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock Text="Carpeta de destino" FontWeight="Medium"/>
                                        <TextBlock Text="Ruta remota donde se guardará el horario." 
                                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{x:Bind ViewModel.RemotePath, Mode=TwoWay}" 
                                             Width="350" VerticalAlignment="Center" PlaceholderText="/UTP Calendar"/>
                                </Grid>

                                <MenuFlyoutSeparator Margin="0"/>

                                <Grid Padding="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock Text="Tiempo límite de subida (Timeout)" FontWeight="Medium"/>
                                        <TextBlock Text="Segundos máximos de espera para la conexión." 
                                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.Timeout, Mode=TwoWay}" 
                                               Minimum="1" SpinButtonPlacementMode="Inline" Width="150" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                                        BorderThickness="0,1,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        CornerRadius="0,0,8,8" Padding="16">
                                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                                        <Button Click="TestConnection_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <SymbolIcon Symbol="Globe"/>
                                                <TextBlock Text="Probar conexión"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Content="Guardar cambios" Click="Save_Click" Style="{ThemeResource AccentButtonStyle}"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>
                    </ContentControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>