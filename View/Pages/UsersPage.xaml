<Page
    x:Class="UTPCalendar.View.Pages.UsersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UTPCalendar.View.Pages"
    xmlns:models="using:UTPCalendar.Models">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Usuarios" 
                   Style="{ThemeResource TitleTextBlockStyle}" 
                   Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox x:Name="SearchBox" 
                            Grid.Column="0"
                            PlaceholderText="Buscar por nombre o código..." 
                            QueryIcon="Find" 
                            MaxWidth="400"
                            HorizontalAlignment="Left"
                            TextChanged="SearchBox_TextChanged"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">

                <DropDownButton Content="Ordenar">
                    <DropDownButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="A-Z (Nombres)" Click="SortAZ_Click"/>
                            <MenuFlyoutItem Text="Z-A (Nombres)" Click="SortZA_Click"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <Button Style="{ThemeResource AccentButtonStyle}" 
                        Click="AddUser_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Add"/>
                        <TextBlock Text="Nuevo Usuario"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>

        <GridView Grid.Row="2" 
                  ItemsSource="{x:Bind ViewModel.FilteredUsers, Mode=OneWay}" 
                  SelectionMode="None">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:UserProfile">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Width="280" 
                            Margin="0,0,16,16" 
                            Padding="16"
                            VerticalAlignment="Top">

                        <Grid>
                            <Button HorizontalAlignment="Right" 
                                    VerticalAlignment="Top" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    Padding="4"
                                    Margin="0,-4,-4,0"
                                    Canvas.ZIndex="1">
                                <SymbolIcon Symbol="More"/>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Actualizar metadatos" Icon="Refresh" Click="UpdateMetadata_Click" Tag="{x:Bind}"/>
                                        <MenuFlyoutItem Text="Editar credenciales" Icon="Edit" Click="EditCredentials_Click" Tag="{x:Bind}"/>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <StackPanel>
                                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,16">
                                    <PersonPicture DisplayName="{x:Bind FullName}" 
                                                   ProfilePicture="{x:Bind ProfileImageSource}" 
                                                   Height="90" Width="90"
                                                   HorizontalAlignment="Center" 
                                                   Margin="0,0,0,12"/>

                                    <TextBlock Text="{x:Bind FullName}" 
                                               FontWeight="SemiBold" 
                                               FontSize="17" 
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               MaxLines="2"
                                               Height="48"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{x:Bind Username}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               FontSize="14"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <MenuFlyoutSeparator Margin="-16,0,-16,12"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" 
                                            HorizontalAlignment="Stretch" 
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Click="GenerateIcs_Click" 
                                            Tag="{x:Bind}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <SymbolIcon Symbol="Calendar"/>
                                            <TextBlock Text="Generar .ics" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Button>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" Margin="4,0,0,0">
                                        <Button Click="SetDefault_Click" 
                                                Tag="{x:Bind}"
                                                Background="Transparent" 
                                                BorderThickness="0"
                                                Padding="8"
                                                ToolTipService.ToolTip="Establecer predeterminado">
                                            <SymbolIcon Symbol="{x:Bind FavoriteSymbol, Mode=OneWay}" 
                                                        Foreground="{x:Bind DefaultStarForeground, Mode=OneWay}"/>
                                        </Button>

                                        <Button Click="InfoUser_Click" 
                                                Tag="{x:Bind}"
                                                Background="Transparent" 
                                                BorderThickness="0"
                                                Padding="8"
                                                ToolTipService.ToolTip="Información académica">
                                            <SymbolIcon Symbol="ContactInfo"/>
                                        </Button>

                                        <Button Click="CopyLink_Click" 
                                                Tag="{x:Bind}"
                                                Background="Transparent" 
                                                BorderThickness="0"
                                                Padding="8"
                                                ToolTipService.ToolTip="Copiar enlace directo de Nextcloud">
                                            <SymbolIcon Symbol="Link"/>
                                        </Button>

                                        <Button Click="DeleteUser_Click" 
                                                Tag="{x:Bind}"
                                                Background="Transparent" 
                                                BorderThickness="0"
                                                Padding="8"
                                                ToolTipService.ToolTip="Eliminar usuario">
                                            <SymbolIcon Symbol="Delete" Foreground="Red"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>