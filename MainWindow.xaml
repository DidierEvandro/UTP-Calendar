<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="UTPCalendar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UTPCalendar"
    Title="UTP Calendar">

    <Grid>
        <Grid.Resources>
            <Storyboard x:Name="RotateSettingsIconStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="SettingIcon"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                    From="0" To="360" Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <BackEase Amplitude="0.3" EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarDragRegion" Grid.Row="0" Background="Transparent">
            <TextBlock
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="UTP Calendar"/>
        </Grid>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            PaneDisplayMode="Left"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.Content>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Frame x:Name="ContentFrame" Grid.Row="0"/>

                    <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="0,1,0,0" Padding="16,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar x:Name="MainProgressBar" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <TextBlock x:Name="ProgressPercentText" Grid.Column="1" Text="0%" 
                                           Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <TextBlock x:Name="StatusText" Text="Listo" Foreground="White" 
                                           FontSize="12.5" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="24">
                                    <TextBlock Foreground="White" VerticalAlignment="Center" FontSize="11">
                                        <Run Text="Última generación .ics: " FontWeight="SemiBold"/>
                                        <Run x:Name="LastIcsText" Text="Nunca"/>
                                    </TextBlock>
                                    <TextBlock Foreground="White" VerticalAlignment="Center" FontSize="11">
                                        <Run Text="Última subida Nextcloud: " FontWeight="SemiBold"/>
                                        <Run x:Name="LastNextcloudText" Text="Nunca"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </NavigationView.Content>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Usuarios" Icon="People" Tag="users"/>
                <NavigationViewItem Content="Recordatorios" Icon="Clock" Tag="reminders"/>
                <NavigationViewItem Content="Nextcloud" Icon="Upload" Tag="nextcloud"/>
                <NavigationViewItem Content="Terminal" Tag="logs">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE756;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Calendario" Icon="Calendar" Tag="calendar"/>
                <NavigationViewItem Content="Ayuda" Icon="Help" Tag="help"/>

                <NavigationViewItem Content="Ajustes" Tag="settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon x:Name="SettingIcon" Symbol="Setting">
                            <SymbolIcon.RenderTransform>
                                <RotateTransform CenterX="10" CenterY="10"/>
                            </SymbolIcon.RenderTransform>
                        </SymbolIcon>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
        </NavigationView>
    </Grid>
</Window>